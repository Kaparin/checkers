{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install -g pnpm@9.15.4 && pnpm install && echo 'build done'"
  },
  "deploy": {
    "startCommand": "pnpm --filter @checkers/api run start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
