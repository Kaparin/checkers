{
  "name": "checkers",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @checkers/db run generate",
    "db:migrate": "pnpm --filter @checkers/db run migrate",
    "db:push": "pnpm --filter @checkers/db run push",
    "db:studio": "pnpm --filter @checkers/db run studio",
    "format": "prettier --write \"**/*.{ts,tsx,json,css}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
